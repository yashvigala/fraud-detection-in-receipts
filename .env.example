# Copy this file to .env and fill in the values.

# ---- Gemini OCR ----
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here
# Override the model if you like (default: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# ---- Twilio (optional) — for voice calls on failed uploads ----
# Sign up at https://www.twilio.com/try-twilio (free trial with $15 credit).
# On the trial you must verify any number you want to call:
#   https://console.twilio.com/us1/develop/phone-numbers/manage/verified
# From the console dashboard, copy these three values:
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Minimum OCR confidence below which we trigger a re-upload call.
# Leave at 0.4 or tweak to taste.
OCR_CONFIDENCE_CALL_THRESHOLD=0.4
